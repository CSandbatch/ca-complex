digraph graph_bridge {
  rankdir=LR;
  graph [fontname="Helvetica" fontsize=13 bgcolor="#ffffff" pad=0.4 label="Signal Atlas - Bridge Between Runtime Data And The UI" labelloc="t"];
  node [fontname="Helvetica" fontsize=10 style=filled color="#333333" shape=box];
  edge [fontname="Helvetica" fontsize=9 color="#555555"];

  raw [label="Raw runtime items\nflat Sources and Events\nplus map geometry" fillcolor="#DBEAFE"];
  project [label="Projection logic\nnormalize item shape,\ncompute scores, attach\nplace and time semantics" fillcolor="#D1FAE5"];
  resolve [label="Resolve UI bundles\nmain grid cards,\nclassifieds rail,\nfocus item, Mixtapes" fillcolor="#EDE0F5"];
  ui [label="Visible product surface" shape=ellipse fillcolor="#F5F5F5"];

  raw -> project;
  project -> resolve;
  resolve -> ui;
}
